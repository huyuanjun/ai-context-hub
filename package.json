{
  "name": "ai-context-hub",
  "version": "0.1.0",
  "description": "Shared memory and skills hub for multiple AI coding tools — zero dependencies, pure Node.js",
  "type": "module",
  "bin": {
    "ai-context": "./src/cli.js"
  },
  "files": [
    "src/",
    "tests/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "start": "node ./src/cli.js",
    "doctor": "node ./src/cli.js doctor",
    "init:hub": "node ./src/cli.js init",
    "test": "node --test tests/*.test.js",
    "test:sync": "node --test tests/sync.test.js",
    "test:skills": "node --test tests/skills.test.js",
    "test:lifecycle": "node --test tests/lifecycle.test.js",
    "test:relations": "node --test tests/relations.test.js",
    "prepublishOnly": "node --test tests/*.test.js"
  },
  "keywords": [
    "ai",
    "memory",
    "skills",
    "cli",
    "context",
    "knowledge-graph",
    "llm",
    "claude",
    "codex",
    "gemini",
    "cursor",
    "windsurf",
    "mcp",
    "tf-idf",
    "semantic-search",
    "zero-dependencies"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/huyuanjun/ai-context-hub"
  },
  "homepage": "https://github.com/huyuanjun/ai-context-hub#readme",
  "bugs": {
    "url": "https://github.com/huyuanjun/ai-context-hub/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
